rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return userDoc().data.role;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (role() == "admin" || role() == "super_admin");
    }

    function isSeller() {
      return isSignedIn() && (role() == "seller" || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ml_accounts/{accountId} {
      allow read: if true;
      allow create: if isSeller();
      allow update: if isSeller();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /rekber_transactions/{rekberId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );

      allow create: if isSeller();
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}